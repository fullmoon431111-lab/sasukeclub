<h2><%= @schedule.title %></h2>
<p>開催日時: <%= @schedule.start_time.strftime("%Y-%m-%d %H:%M") %></p>

<h3>参加者一覧</h3>
<ul>
  <% @schedule.users.each do |user| %>
    <li><%= user.name %></li>
  <% end %>
</ul>

<% if user_signed_in? %>
  <% if @schedule.users.include?(current_user) %>
    <%= button_to "参加キャンセル", leave_schedule_path(@schedule), method: :delete %>
  <% else %>
    <%= button_to "参加する", join_schedule_path(@schedule), method: :post %>
  <% end %>
<% end %>

<%= link_to "一覧へ戻る", schedules_path %>